{
  "name": "medbridge",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "docker compose up -d && pnpm -r --parallel --stream dev",
    "build": "pnpm -r --filter=./packages/* build && pnpm -r --filter=./apps/* build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --config=test/e2e/playwright.config.ts",
    "typecheck": "pnpm -r --parallel typecheck",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:push": "pnpm --filter @medbridge/api db:push",
    "db:studio": "pnpm --filter @medbridge/api db:studio",
    "db:seed": "pnpm --filter @medbridge/api db:seed",
    "verify": "pnpm typecheck && pnpm test && pnpm lint"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.0"
  }
}
