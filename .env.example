# Copy to .env and adjust as needed: cp .env.example .env

# Postgres connection string used by the API and Drizzle.
# Matches the docker-compose service.
DATABASE_URL=postgres://medbridge:medbridge@localhost:5432/medbridge

# JWT signing secret (HS256). MUST be at least 32 characters or the API will refuse to boot.
# This is a development-only placeholder; rotate for any non-dev environment.
JWT_SECRET=dev-only-change-me-please-32-chars-min

# Hono API listen port.
API_PORT=3001

# Vite dev server port.
WEB_PORT=5173

# Public base URL the web app uses to reach the API.
VITE_API_BASE_URL=http://localhost:3001
